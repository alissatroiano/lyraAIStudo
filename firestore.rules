rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true
        || !("email_verified" in request.auth.token)
        || request.auth.token.email_verified == null
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validation helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) 
        && data.keys().size() <= 15
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 128))
        && (!data.keys().hasAny(['customPreferences']) || (data.customPreferences is string && data.customPreferences.size() <= 5000))
        && (!data.keys().hasAny(['grade']) || (data.grade is string))
        && (!data.keys().hasAny(['classSize']) || (data.classSize is string))
        && (!data.keys().hasAny(['duration']) || (data.duration is string))
        && (!data.keys().hasAny(['tech']) || (data.tech is string))
        && (!data.keys().hasAny(['instructorNotes']) || (data.instructorNotes is string))
        && (!data.keys().hasAny(['isSubscribed']) || (data.isSubscribed is bool))
        && (!data.keys().hasAny(['stripeCustomerId']) || (data.stripeCustomerId is string && data.stripeCustomerId.size() <= 128))
        && (!data.keys().hasAny(['stripeSubscriptionId']) || (data.stripeSubscriptionId is string && data.stripeSubscriptionId.size() <= 128))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['id', 'userId', 'lessonTitle', 'duration', 'summary', 'createdAt', 'updatedAt'])
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.lessonTitle is string && data.lessonTitle.size() <= 200
        && data.duration is string && data.duration.size() <= 100
        && data.summary is string && data.summary.size() <= 10000
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (!data.keys().hasAny(['keyTakeaways']) || (data.keyTakeaways is list && data.keyTakeaways.size() <= 20))
        && (!data.keys().hasAny(['slides']) || (data.slides is list && data.slides.size() <= 20))
        && (!data.keys().hasAny(['handsOnActivity']) || (data.handsOnActivity is map))
        && (!data.keys().hasAny(['worksheet']) || (data.worksheet is map))
        && (!data.keys().hasAny(['quiz']) || (data.quiz is list && data.quiz.size() <= 50))
        && (!data.keys().hasAny(['mediaRecommendations']) || (data.mediaRecommendations is list && data.mediaRecommendations.size() <= 20));
    }

    // 2. User Profiles Collection Rules
    match /users/{userId} {
      allow get: if isEmailVerified() && userId == request.auth.uid;
      allow create: if isEmailVerified() 
        && userId == request.auth.uid 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid
        && (incoming().createdAt == request.time || incoming().createdAt is timestamp)
        && (incoming().updatedAt == request.time || incoming().updatedAt is timestamp);
        
      allow update: if isEmailVerified()
        && userId == request.auth.uid
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid
        && incoming().createdAt == existing().createdAt
        && (incoming().updatedAt == request.time || incoming().updatedAt is timestamp)
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt', 'customPreferences', 'grade', 'classSize', 'duration', 'tech', 'instructorNotes', 'isSubscribed', 'stripeCustomerId', 'stripeSubscriptionId']);
        
      allow delete: if false; // Profiles are permanent once created
    }

    // 3. Lessons Collection Rules
    match /lessons/{lessonId} {
      allow get: if isEmailVerified() && existing().userId == request.auth.uid;
      allow list: if isEmailVerified() && resource.data.userId == request.auth.uid;
      
      allow create: if isEmailVerified()
        && isValidId(lessonId)
        && isValidLesson(incoming())
        && incoming().userId == request.auth.uid
        && incoming().id == lessonId
        && (incoming().createdAt == request.time || incoming().createdAt is timestamp)
        && (incoming().updatedAt == request.time || incoming().updatedAt is timestamp);

      allow update: if isEmailVerified()
        && existing().userId == request.auth.uid
        && isValidLesson(incoming())
        && incoming().userId == existing().userId
        && incoming().id == existing().id
        && incoming().createdAt == existing().createdAt
        && (incoming().updatedAt == request.time || incoming().updatedAt is timestamp);

      allow delete: if isEmailVerified() && existing().userId == request.auth.uid;
    }
  }
}
